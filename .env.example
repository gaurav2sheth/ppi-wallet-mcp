# PPI Wallet — MCP Server (mcp)
# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env`.

# Anthropic API key for Claude-powered agents and chat handler.
# Without this, agents fall back to keyword/template mode (functional but
# less personalised). See docs/ai-agents.md for the fallback behaviour.
ANTHROPIC_API_KEY=

# Scheduler toggle — set to 'false' to prevent the daily KYC cron jobs
# from auto-starting when the server boots. Useful for local dev.
ENABLE_SCHEDULER=true
